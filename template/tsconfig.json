{
	"include": ["src/**/*"],
	"compilerOptions": {
		"strict": true,

		"rootDir": "./src",
		"outDir": "./dist",
		"paths": {
			"@/*": ["./src/*"]
		},

		"target": "es2020",
		"lib": ["es2020"],
		"types": ["scriptable-jsx/env"],
		"module": "preserve",
		"moduleResolution": "bundler",
		"esModuleInterop": true,

		"jsx": "react-jsx",
		"jsxImportSource": "scriptable-jsx"
	}
}