{
	"compilerOptions": {
		"strict": true,

		"rootDir": "src",
		"outDir": ".",

		"lib": ["ESNext"],
		"target": "ESNext",
		"module": "Preserve",
		"moduleDetection": "force",
		
		"plugins": [
			{"transform": "./src/transformer/scriptable-transformer.ts", "after": true}
		],

		"baseUrl": "src",
		"paths": {
			"@/*": ["./*"]
		}
	},
	"include": ["src/**/*", "scriptable.d.ts"],
	"exclude": []
}